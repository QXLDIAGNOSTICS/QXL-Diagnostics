# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=QXL Backend
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_BYTES=26214400

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb

# Auth0 (API — validates Bearer access tokens on protected endpoints)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.yourapp.com
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_ALGORITHMS=RS256

# Auth0 (Regular Web App — backend-owned login flow)
AUTH0_CLIENT_ID=your-regular-web-app-client-id
AUTH0_CLIENT_SECRET=your-regular-web-app-client-secret
AUTH0_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback
FRONTEND_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=qxl_session
SESSION_TTL_DAYS=14

# Supabase (service role key is server-side ONLY — never expose to the client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=user-files

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
CHAT_HISTORY_LIMIT=10
