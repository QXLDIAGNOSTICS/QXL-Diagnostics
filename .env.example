# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=QXL Backend
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_BYTES=26214400

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb

# First-party auth
FRONTEND_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=qxl_session
SESSION_TTL_DAYS=14
PASSWORD_MIN_LENGTH=8
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
OTP_LENGTH=8
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
LOGIN_CHALLENGE_TTL_SECONDS=900

# SMS (Nettyfish SmartSMS)
NETTYFISH_BASE_URL=https://sms.nettyfish.com
NETTYFISH_API_KEY=
NETTYFISH_CLIENT_ID=
NETTYFISH_SENDER_ID=
NETTYFISH_PRINCIPLE_ENTITY_ID=
NETTYFISH_TEMPLATE_ID=
NETTYFISH_SERVICE_ID=
NETTYFISH_VALIDITY_PERIOD=5m

# Email (SMTP) — secondary OTP delivery channel
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@qxldiagnostics.com
SMTP_USE_TLS=true

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Prescriptions
PRESCRIPTION_MONTHLY_UPLOAD_LIMIT=5

# Shared admin secret required during admin OTP verification.
# ADMIN_SUPER_IDENTIFIERS is a comma-separated list of emails/phones that should
# be treated as super_admin on successful admin login.
ADMIN_ACCESS_KEY=
ADMIN_SUPER_IDENTIFIERS=

# Supabase (service role key is server-side ONLY — never expose to the client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=user-files

# Cloudinary — public, permanent hosting for admin-managed CMS images (doctor
# photos, banner artwork, blog cover images). Get these from your Cloudinary
# dashboard (Settings > API Keys). Leave blank to disable image uploads (the
# admin panel will still accept manually-typed URLs).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=qxl

CLOUDINARY_URL

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
CHAT_HISTORY_LIMIT=10
